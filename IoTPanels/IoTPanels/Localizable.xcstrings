    "The server certificate will be validated against the system's trusted certificate authorities. Add a custom CA for self-signed or private CA certificates." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Serverzertifikat wird gegen die vertrauenswürdigen Zertifizierungsstellen des Systems geprüft. Füge eine benutzerdefinierte CA für selbstsignierte oder private CA-Zertifikate hinzu."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El certificado del servidor se validará contra las autoridades de certificación de confianza del sistema. Añada una CA personalizada para certificados autofirmados o de CA privada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le certificat du serveur sera valide par rapport aux autorites de certification de confiance du systeme. Ajoutez une CA personnalisée pour les certificats auto-signes ou de CA privee."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サーバー証明書はシステムの信頼された認証局に対して検証されます。自己署名証明書やプライベートCAの場合はカスタムCAを追加してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "서버 인증서가 시스템의 신뢰할 수 있는 인증 기관에 대해 검증됩니다. 자체 서명 또는 사설 CA 인증서의 경우 사용자 지정 CA를 추가하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O certificado do servidor será validado contra as autoridades de certificação confiáveis do sistema. Adicione uma CA personalizada para certificados autoassinados ou de CA privada."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "服务器证书将根据系统信任的证书颁发机构进行验证。对于自签名或私有 CA 证书，请添加自定义 CA。"
          }
        }
      }
    },
    "This data source generates realistic demo data for testing. No network connection required." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Datenquelle erzeugt realistische Demodaten zum Testen. Keine Netzwerkverbindung erforderlich."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta fuente de datos genera datos de demostración realistas para pruebas. No requiere conexión de red."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette source de données généré des données de démonstration realistes pour les tests. Aucune connexion reseau requise."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このデータソースはテスト用のリアルなデモデータを生成します。ネットワーク接続は不要です。"
