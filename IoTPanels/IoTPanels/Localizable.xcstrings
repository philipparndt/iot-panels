    "Your password is only used to sign in and create an API token. It will not be stored.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Passwort wird nur zur Anmeldung und Erstellung eines API-Tokens verwendet. Es wird nicht gespeichert."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre mot de passe est uniquement utilise pour se connecter et créer un token API. Il ne sera pas enregistre."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Su contraseña solo se usa para iniciar sesión y crear un token API. No se almacenará."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パスワードはサインインとAPIトークンの作成にのみ使用されます。保存されません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的密码仅用于登录和创建 API 令牌，不会被存储。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua senha é usada apenas para fazer login e criar um token API. Ela não será armazenada."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "비밀번호는 로그인과 API 토큰 생성에만 사용됩니다. 저장되지 않습니다."
          }
        }
      }
    },
