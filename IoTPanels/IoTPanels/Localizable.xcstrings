          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso excluirá permanentemente esta casa e todos os seus painéis, fontes de dados e widgets."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 홈과 모든 대시보드, 데이터 소스, 위젯이 영구적으로 삭제됩니다."
          }
        }
      }
