    "A PKCS#12 file (.p12 or .pfx) is a secure container that bundles your client certificate and private key together, protected by a password." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine PKCS#12-Datei (.p12 oder .pfx) ist ein sicherer Container, der dein Client-Zertifikat und deinen privaten Schlüssel zusammen bündelt, geschützt durch ein Passwort."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un archivo PKCS#12 (.p12 o .pfx) es un contenedor seguro que agrupa su certificado de cliente y clave privada, protegido por una contraseña."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un fichier PKCS#12 (.p12 ou .pfx) est un conteneur securise qui regroupe votre certificat client et votre clé privee, protégé par un mot de passe."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PKCS#12ファイル（.p12または.pfx）は、クライアント証明書と秘密鍵をパスワードで保護してまとめた安全なコンテナです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PKCS#12 파일(.p12 또는 .pfx)은 클라이언트 인증서와 개인 키를 비밀번호로 보호하여 하나로 묶은 보안 컨테이너입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um arquivo PKCS#12 (.p12 ou .pfx) é um contêiner seguro que agrupa seu certificado de cliente e chave privada, protegido por uma senha."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PKCS#12 文件（.p12 或 .pfx）是一个安全容器，将您的客户端证书和私钥捆绑在一起，并受密码保护。"
          }
        }
      }
    },
