    "Items with the same group name will be rendered as multiple curves on one chart.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Elemente mit demselben Gruppennamen werden als mehrere Kurven in einem Diagramm dargestellt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les éléments avec le meme nom de groupe seront affiches comme plusieurs courbes sur un seul graphique."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los elementos con el mismo nombre de grupo se mostrarán como múltiples curvas en un gráfico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同じグループ名の項目は1つのチャートに複数の曲線として表示されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "相同分组名称的项目将在同一图表上显示为多条曲线。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Itens com o mesmo nome de grupo serão exibidos como múltiplas curvas em um gráfico."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "같은 그룹 이름의 항목은 하나의 차트에 여러 곡선으로 표시됩니다."
          }
        }
      }
    },
