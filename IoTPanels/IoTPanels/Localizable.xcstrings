    "A PKCS#12 file (.p12 or .pfx) is a secure container that bundles your client certificate and private key together, protected by a password.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine PKCS#12-Datei (.p12 oder .pfx) ist ein sicherer Container, der dein Client-Zertifikat und deinen privaten Schlüssel zusammen bündelt, geschützt durch ein Passwort."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un fichier PKCS#12 (.p12 ou .pfx) est un conteneur securise qui regroupe votre certificat client et votre clé privee, protégé par un mot de passe."
          }
        }
      }
    },
