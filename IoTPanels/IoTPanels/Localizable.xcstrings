    "Messages are delivered at least once. Acknowledged by receiver. May cause duplicates." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nachrichten werden mindestens einmal zugestellt. Vom Empfänger bestätigt. Kann Duplikate verursachen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los mensajes se entregan al menos una vez. Confirmados por el receptor. Puede causar duplicados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les messages sont livres au moins une fois. Accuses de reception par le recepteur. Peut causer des doublons."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メッセージは少なくとも1回配信されます。受信者が確認応答します。重複する場合があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메시지가 최소 한 번 전달됩니다. 수신자가 확인합니다. 중복이 발생할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mensagens são entregues pelo menos uma vez. Confirmadas pelo receptor. Pode causar duplicatas."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "消息至少传递一次。由接收者确认。可能导致重复。"
          }
        }
      }
    },
    "Messages are delivered at most once. No acknowledgement. Fastest but may lose messages." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nachrichten werden höchstens einmal zugestellt. Keine Bestätigung. Am schnellsten, aber Nachrichten können verloren gehen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los mensajes se entregan como máximo una vez. Sin confirmación. Más rápido pero puede perder mensajes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les messages sont livres au plus une fois. Pas d'accusé de reception. Le plus rapide mais peut perdre des messages."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メッセージは最大1回配信されます。確認応答なし。最速ですがメッセージが失われる可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메시지가 최대 한 번 전달됩니다. 확인 없음. 가장 빠르지만 메시지가 손실될 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mensagens são entregues no máximo uma vez. Sem confirmação. Mais rápido, mas pode perder mensagens."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "消息最多传递一次。无确认。最快但可能丢失消息。"
          }
        }
      }
    },
    "Messages are delivered exactly once. Four-step handshake. Slowest but most reliable." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nachrichten werden genau einmal zugestellt. Vier-Schritte-Handshake. Am langsamsten, aber am zuverlässigsten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los mensajes se entregan exactamente una vez. Protocolo de cuatro pasos. Más lento pero más fiable."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les messages sont livres exactement une fois. Poignee de main en quatre etapes. Le plus lent mais le plus fiable."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メッセージは正確に1回配信されます。4段階のハンドシェイク。最も遅いですが最も信頼性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메시지가 정확히 한 번 전달됩니다. 4단계 핸드셰이크. 가장 느리지만 가장 신뢰할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
